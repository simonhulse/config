#!/usr/bin/csh
cd ~/progs

if ( -d nmrpipe ) then
    rm -r nmrpipe
endif

mkdir nmrpipe
cd nmrpipe

wget https://www.ibbr.umd.edu/nmrpipe/install.com
wget https://www.ibbr.umd.edu/nmrpipe/binval.com
wget https://www.ibbr.umd.edu/nmrpipe/NMRPipeX.tZ
wget https://www.ibbr.umd.edu/nmrpipe/s.tZ
wget https://www.ibbr.umd.edu/nmrpipe/dyn.tZ


set DIRECTORY="Downloads/nmrpipe_install"

cp "$DIRECTORY/install.com" .
cp "$DIRECTORY/binval.com" .
cp "$DIRECTORY/NMRPipeX.tZ" .
cp "$DIRECTORY/s.tZ" .
cp "$DIRECTORY/plugin.smile.tZ" .

chmod a+r *.tZ
chmod a+rx *.com

./install.com

rm ~/.cshrc

cd
