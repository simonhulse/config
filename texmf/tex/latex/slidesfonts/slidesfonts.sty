\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{slidesfonts}[2026/06/02 Font configuration for beamer slide classes]

\RequirePackage{fontspec}
\RequirePackage[math-style=ISO,bold-style=ISO]{unicode-math}

\setmainfont{Fira Sans}[BoldFont={Fira Sans SemiBold}]
\setsansfont{Fira Sans}[BoldFont={Fira Sans SemiBold}]
\setmathfont{FiraMath-Regular}[Extension=.otf, Scale=MatchLowercase]
\setmonofont{Fira Mono}[Scale=MatchLowercase]
